# Required for chat (BYOK — users can also provide via browser)
ANTHROPIC_API_KEY=

# Required for invite-link JWT signing
INVITE_SECRET=change-me-to-a-random-secret

# Optional: Supabase (Phase 2)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Project-document upload pipeline (Phase 2)
# Daily spend cap (cents) for the project-document vision extraction path.
# Separate counter from any other vision budget.
PROJECT_DOC_VISION_DAILY_LIMIT_CENTS=500
# Maximum upload size in bytes (default 25 MB).
PROJECT_DOC_MAX_BYTES=25000000
# Daily spend cap (cents) for the deed-decode endpoint.
DEED_DECODE_DAILY_LIMIT_CENTS=500
# Anthropic model used by vision extractors.
VISION_MODEL=claude-opus-4-7
