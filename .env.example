# Required for chat (BYOK — users can also provide via browser)
ANTHROPIC_API_KEY=

# Required for invite-link JWT signing
INVITE_SECRET=change-me-to-a-random-secret

# Optional: Supabase (Phase 2 + Phase 5B AI Project Companion)
# All three Supabase vars are optional; when absent the web app boots
# without project storage and helpers fall back to null.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — keep this off the client at all costs.
# SUPABASE_SERVICE_ROLE_KEY=
