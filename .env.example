# --- Security / secrets ---------------------------------------------------

# Operator-funded fallback Anthropic key. Optional. When set, anonymous
# users (no BYOK in the chat panel) get a small per-IP daily quota on
# /api/chat backed by this key, served by claude-haiku-4-5-20251001 to keep
# cost down. Leave blank to disable the free tier; users must then bring
# their own key.
#
# Also used as the operator-funded key for /api/deed-decode (Tab 2 of the
# Deed Decoder), gated by a per-day spend cap (DEED_VISION_DAILY_LIMIT_CENTS).
ANTHROPIC_API_KEY=

# HMAC secret used to sign invite-link JWTs. Required if you mint invite
# tokens via /invite. Must be at least 16 characters of high-entropy input.
# Generate one with: openssl rand -base64 32
INVITE_SECRET=change-me-to-a-random-secret-min-16-chars

# --- Optional features ----------------------------------------------------

# Per-IP daily cap on operator-funded chat requests (anonymous users).
# Default: 10. Increase if you have a generous Anthropic spend cap.
OPERATOR_CHAT_DAILY_LIMIT=10

# Daily spend cap for the deed-decode vision route, in cents. Default 200 ($2/day).
DEED_VISION_DAILY_LIMIT_CENTS=200

# Per-IP hourly rate limit for the deed-decode vision route. Default 5.
DEED_VISION_RATE_LIMIT_PER_HOUR=5

# Override for the markdown content root. Defaults to ../content relative
# to the web app. Useful in tests or when deploying a forked content tree.
# CIVIL3D_CONTENT_ROOT=

# --- Deployment -----------------------------------------------------------

# Canonical public URL of the deployment. Used for absolute links in
# metadata and structured data. Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Supabase (Phase 2)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
