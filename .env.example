# Required for chat (BYOK — users can also provide via browser)
ANTHROPIC_API_KEY=

# Required for invite-link JWT signing
INVITE_SECRET=change-me-to-a-random-secret

# Optional: Supabase (Phase 2)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: extra origins allowed to iframe /embed/* calculator widgets.
# Whitespace-separated list of CSP source expressions. 'self' is always
# included implicitly; leaving this unset means only the site itself
# may embed the widgets. Wildcards and schemes are supported, e.g.:
#   EMBED_ALLOWED_FRAME_ANCESTORS="https://example.edu https://*.example.edu"
EMBED_ALLOWED_FRAME_ANCESTORS=
