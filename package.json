{
  "name": "civil3d-master-guide",
  "version": "0.1.0",
  "private": true,
  "description": "Master knowledge base for land surveying and civil engineering in Civil 3D",
  "license": "CC-BY-SA-4.0 AND MIT",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "web",
    "mcp-server"
  ],
  "scripts": {
    "build:llms": "node scripts/build-llms-txt.mjs",
    "seed:commands": "node scripts/seed-civil3d-commands.mjs",
    "verify:links": "node scripts/verify-jurisdiction-links.mjs",
    "new-page": "node scripts/new-page.mjs",
    "lint:content": "node scripts/lint-content.mjs",
    "lint:lisp": "node scripts/lint-lisp.mjs",
    "lint:all": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run build",
    "audit:frontmatter": "node scripts/audit-frontmatter.mjs",
    "test:scripts": "node --test scripts/__tests__/",
    "test:lint-lisp": "node --test scripts/__tests__/lint-lisp.test.mjs",
    "build:exports": "node scripts/build-exports.mjs",
    "build:all": "node scripts/build-all.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "gray-matter": "^4.0.3",
    "vitest": "^2.1.9"
  }
}
