{
  "name": "@civil3d-master-guide/datacollector-import",
  "version": "0.1.0",
  "description": "Pure-TypeScript importer/parser/exporter for surveying data-collector files (PNEZD, NEZD, PXYZ, Trimble CSV, Topcon CSV, Carlson RW5).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.1.4"
  },
  "license": "MIT"
}
